// vajra.varta — Vajra's own operating context, in Varta. v0 (S19).
// COMPANION, not replacement: .ai/*.md stays source of truth; this is the agent-facing render.
// Boot ritual: read this, internalize ⚡forbid + ⚡max + ⚡final, then speak Varta all session.

⚡project {
  ⚡is    "one CLI that guides any AI coding agent through a project step by step";
  ⚡stack "Rust / single static binary (pkg vajractl, bin vajra) / Apache-2.0 OSS";
  ⚡goal  "vajra next = the cross-agent workflow coach. co-pilot, not cop.";   // never drift from this
  ⚡now   "Varta v0 — the skill (Session 19)";
}

⚡forbid {                       // violation = STOP and ask
  work_on_main;                 // branch session-NN-slug first; main + master are protected
  commit_without_approval;      // wait for: approved | lgtm | ship it | yes commit | go ahead
  autonomous_commit;            // a human says when
  code_in_ground_truth;         // every 5th session (NN % 5 == 0) is NO-CODE; hook-enforced
  skip_hooks;                   // no --no-verify; the hooks ARE the product
  force_push_to_main;           // never rewrite shared history
}

⚡require {                      // invariants — hold at all times
  verify_exits_0_before_done;   // a check that cannot evaluate FAILS; never leave red
  state_is_snapshot_not_log;    // STATE.md is overwritten in full, never appended
  branch_matches "^session-\\d{2,}-[a-z0-9-]+$";   // session branch naming
  max_7_top_level_commands;     // SuperClaude's 30+ commands are its #1 complaint
}

⚡max {                          // cross one => split or stop
  assumptions       = 2;        // 3rd => STOP and ask
  retries           = 2;        // 3rd failure => escalate
  files_per_commit  = 3;        // atomic; hook-enforced
  stories_per_session = 1;      // larger => split the session
  hours_per_session = 2;        // marathon = drift
  words_per_response = 200;     // bullets + tables + code, no prose walls
}

⚡pipeline {                     // the session loop, in order
  boot -> branch -> plan -> execute -> verify -> pr -> summary -> next -> closeout;
}

⚡final {                        // locked ADRs — changing one needs explicit human approval
  ADR_0001: "compression ships via Claude Code PostToolUse hook, not a PATH-shim";   // 2026-06-15
  ADR_0002: "Engine trait + EngineDecision enum + single crate, no adapter trait in v1";   // 2026-06-16
  ADR_0003: "--settings tempfile-merge injector; LINE_CAP=30; FAIL_PASSTHROUGH_CAP=400";   // 2026-06-16
  ADR_0004: "meter/receipt: on-exit JSONL parse, compiled-in pricing, receipt to stderr";   // 2026-06-16
  ADR_0005: "pre-run estimate: chars/4 input, 3:1 output (placeholder), Opus pricing";   // 2026-06-27
}

// ⚡on — the co-pilot. fire each ONLY when you touch that work, not up front.
⚡on (compression)   ⚡include "src/engine/*", "research/*fixtures*";   // heuristics + golden fixtures
⚡on (launcher)      ⚡include "src/launcher/*", "src/adapter/*";       // settings injection + CC wire
⚡on (new_command)   ⚡include "src/cli/*", ".ai/ROADMAP.md";           // honor the max-7-commands rule
⚡on (drift_check)   ⚡include ".ai/STATE.md", git_status;              // claimed state vs real state
⚡on (closeout)      ⚡include "scripts/verify-closeout.sh", ".ai/";    // sync all .ai/, must exit 0

⚡assert {                       // pre-ship checklist — shaky answer => do not ship
  what_can_break?;              // name the failure mode
  hidden_assumptions?;          // list them; max 2 total
  production_ready?;            // would it survive a real session, not just tests
  patches_only_on_repro?;      // no defensive code without repro evidence
  scope_intact?;               // still 1 story, ≤3 files, on-branch
}

⚡enum next {                    // filled at end-of-session closeout (Step 7) — exactly 3
  A: "<option>";                // why pick / key risk
  B: "<option>";                // why pick / key risk
  C: "<option>";                // why pick / key risk
}
